{
  "compilerOptions": {
    "jsx": "react-native",
    "target": "ESNext",
    "lib": ["ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["react-native", "react", "expo-router"]
  },
  "include": ["app", "components", "lib"]
}
